{
  "name": "@meld-ts/core",
  "description": "A collection of utility functions for TypeScript",
  "version": "1.0.0",
  "type": "module",
  "files": [
    "./dist",
    "./browser"
  ],
  "module": "./dist/index.js",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./timer": {
      "import": {
        "types": "./dist/timer.d.ts",
        "default": "./dist/timer.js"
      },
      "require": {
        "types": "./dist/timer.d.cts",
        "default": "./dist/timer.cjs"
      }
    },
    "./singleton": {
      "import": {
        "types": "./dist/singleton.d.ts",
        "default": "./dist/singleton.js"
      },
      "require": {
        "types": "./dist/singleton.d.cts",
        "default": "./dist/singleton.cjs"
      }
    },
    "./path": {
      "import": {
        "types": "./dist/path.d.ts",
        "default": "./dist/path.js"
      },
      "require": {
        "types": "./dist/path.d.cts",
        "default": "./dist/path.cjs"
      }
    },
    "./traits": {
      "require": {
        "types": "./dist/traits/index.d.cts",
        "default": "./dist/traits/index.cjs"
      },
      "import": {
        "types": "./dist/traits/index.d.ts",
        "default": "./dist/traits/index.js"
      }
    },
    "./events": {
      "import": {
        "types": "./dist/events/index.d.ts",
        "default": "./dist/events/index.js"
      },
      "require": {
        "types": "./dist/events/index.d.cts",
        "default": "./dist/events/index.cjs"
      }
    },
    "./async": {
      "require": {
        "types": "./dist/async/index.d.cts",
        "default": "./dist/async/index.cjs"
      },
      "import": {
        "types": "./dist/async/index.d.ts",
        "default": "./dist/async/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "keywords": [
    "typescript",
    "utility",
    "functions",
    "utils",
    "type-guards",
    "async",
    "traits"
  ],
  "author": "Jiankai Zeng <janpoem@163.com>",
  "contributors": [
    {
      "name": "KAI@AI-SOUL"
    },
    {
      "name": "思源@AI-SOUL"
    }
  ],
  "license": "MIT",
  "scripts": {
    "fmt": "biome format --write ./src",
    "lint": "biome lint --error-on-warnings ./src",
    "ts-check": "tsgo --noEmit",
    "test": "bun test src/ --coverage",
    "build:exports": "bunup --exports",
    "build:browser": "bunup --config bunup.browser.ts",
    "build:dist": "bunup",
    "build": "bun run build:browser && bun run build:dist",
    "doc": "bun typedoc --options typedoc.json --cleanOutputDir"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/bun": "latest",
    "@typescript/native-preview": "^7.0.0-dev.20260611.2",
    "bunup": "^0.16.32"
  },
  "peerDependencies": {
    "typescript": "^6"
  }
}