{
  "name": "@meld-ts/core",
  "description": "A collection of utility functions for TypeScript",
  "version": "1.0.0",
  "type": "module",
  "files": [
    "./dist"
  ],
  "module": "./dist/index.js",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "keywords": [
    "typescript",
    "utility",
    "functions",
    "utils",
    "type-guard",
    "async",
    "traits"
  ],
  "author": "Jiankai Zeng <janpoem@163.com>",
  "contributors": [
    {
      "name": "KAI@AI-SOUL"
    }
  ],
  "license": "MIT",
  "scripts": {
    "lint": "biome lint --error-on-warnings ./src",
    "fmt": "biome format --write ./src",
    "ts-check": "tsgo --noEmit",
    "test": "bun test src/ --coverage",
    "build": "bunup",
    "doc": "bun typedoc --options typedoc.json --cleanOutputDir"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/bun": "latest",
    "@typescript/native-preview": "^7.0.0-dev.20260611.2",
    "bunup": "^0.16.32"
  },
  "peerDependencies": {
    "typescript": "^6"
  }
}